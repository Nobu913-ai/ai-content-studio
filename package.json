{
  "name": "ai-content-studio",
  "version": "2.2.0",
  "description": "3チャンネル統合 YouTube コンテンツ制作パイプライン (Claude API)",
  "main": "src/cli.js",
  "scripts": {
    "start": "node src/cli.js",
    "channels": "node src/cli.js channels",
    "status": "node src/cli.js status",
    "test": "node --test src/tests/**/*.test.js",
    "lint": "eslint src/ config/",
    "format": "prettier --write src/ config/",
    "format:check": "prettier --check src/ config/"
  },
  "keywords": [
    "youtube",
    "ai",
    "content-creation",
    "claude"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bin": {
    "acs": "./src/cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nobu913-ai/ai-content-studio.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  }
}
