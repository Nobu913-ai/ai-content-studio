# Anthropic API Key (optional — 設定時: 自動生成 / 未設定時: プロンプト書き出し → Claude Code で手動実行)
# https://console.anthropic.com/ で取得
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Runway API Key (optional — 動画生成)
# https://app.runwayml.com/ で取得
# RUNWAY_API_KEY=your-runway-key-here

# ElevenLabs API Key (optional — 音声生成)
# https://elevenlabs.io/ で取得
# ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Descript API Key (optional — AI編集)
# https://www.descript.com/ で取得
# DESCRIPT_API_KEY=your-descript-key-here
