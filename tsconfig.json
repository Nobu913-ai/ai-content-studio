{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src/remotion/**/*.ts", "src/remotion/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
