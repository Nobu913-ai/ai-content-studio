  "cumulativeFinalSec": 58.159,
  "segments": [
    {
      "idx": 1,
      "start": 0,
      "end": 4.736,
      "dur": 4.736,
      "text": "投資で100万円儲けても、普通の口座だと税金で約20万円取られる。"
    },
    {
      "idx": 2,
      "start": 4.836,
      "end": 7.577,
      "dur": 2.741,
      "text": "でもしんニーサなら、100万円まるまる残る。"
    },
    {
      "idx": 3,
      "start": 7.677,
      "end": 8.947,
      "dur": 1.269,
      "text": "これが、しんニーサ。"
    },
    {
      "idx": 4,
      "start": 9.047,
      "end": 11.532,
      "dur": 2.485,
      "text": "いま使える、国の非課税投資制度。"
    },
    {
      "idx": 5,
      "start": 11.632,
      "end": 20.613,
      "dur": 8.981,
      "text": "つみたて投資枠が年間120万円。成長投資枠が年間240万円。合計360万円まで非課税で投資できる。"
    },
    {
      "idx": 6,
      "start": 20.713,
      "end": 22.729,
      "dur": 2.016,
      "text": "しかも非課税期間は、無期限。"
    },
    {
      "idx": 7,
      "start": 22.829,
      "end": 25.869,
      "dur": 3.04,
      "text": "最初はつみたて投資枠から検討する人が多い。"
    },
    {
      "idx": 8,
      "start": 25.969,
      "end": 27.207,
      "dur": 1.237,
      "text": "始め方はシンプル。"
    },
    {
      "idx": 9,
      "start": 27.307,
      "end": 31.253,
      "dur": 3.947,
      "text": "ネット証券でニーサ口座を開設して、つみたて設定するだけ。"
    },
    {
      "idx": 10,
      "start": 31.353,
      "end": 34.297,
      "dur": 2.944,
      "text": "最短ならスマホでサクッと申込みまで進められる。"
    },
    {
      "idx": 11,
      "start": 34.397,
      "end": 37.107,
      "dur": 2.709,
      "text": "月100円からつみたてできる証券会社もある。"
    },
    {
      "idx": 12,
      "start": 37.207,
      "end": 39.511,
      "dur": 2.304,
      "text": "つまり、お試し感覚でも始められる。"
    },
    {
      "idx": 13,
      "start": 39.611,
      "end": 40.827,
      "dur": 1.216,
      "text": "少額からスタート。"
    },
    {
      "idx": 14,
      "start": 40.927,
      "end": 42.857,
      "dur": 1.931,
      "text": "慣れてきたら金額を増やしていく。"
    },
    {
      "idx": 15,
      "start": 42.957,
      "end": 45.165,
      "dur": 2.208,
      "text": "毎月コツコツが資産形成のコツ。"
    },
    {
      "idx": 16,
      "start": 45.265,
      "end": 47.857,
      "dur": 2.592,
      "text": "続けるほど、複利で資産が育ちやすい。"
    },
    {
      "idx": 17,
      "start": 47.957,
      "end": 54.261,
      "dur": 6.304,
      "text": "価格変動リスクがあるので、最初は少額で様子を見ながら、無理のない範囲で続けることが大切です。"
    },
    {
      "idx": 18,
      "start": 54.361,
      "end": 58.159,
      "dur": 3.797,
      "text": "詳しい始め方の完全ガイドは、固定コメントかプロフィールへ。"
    }
  ],
